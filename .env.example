# Server-side — lives in the Express process only, never shipped to the browser.
# Copy this to .env at the repo root, and `server/.env` picks it up on `npm run dev:server`.

# Which LLM provider the server uses. Falls back to ollama in dev, gemini otherwise.
# LLM_PROVIDER=gemini

# Gemini (only needed when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-key-from-https://aistudio.google.com/apikey

# Ollama (only needed when LLM_PROVIDER=ollama)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# CORS allowlist for the API. Defaults to `true` (all origins) in dev only;
# SET THIS EXPLICITLY in production — e.g. CORS_ORIGIN=https://your-app.web.app
# CORS_ORIGIN=http://localhost:5173

# Firebase service account — either a filesystem path (relative to server/) or
# the full JSON blob as a single string. See server/src/services/firebase.ts.
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account", ... }
