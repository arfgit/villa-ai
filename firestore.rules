rules_version = '2';

// Villa AI stores everything (sessions, training data, wisdom) server-side
// via the Express app running on Cloud Functions. The server authenticates
// to Firestore via the admin SDK (firebase-admin), which BYPASSES these
// rules entirely.
//
// Therefore: clients should NEVER talk to Firestore directly. This file
// locks that down as a defense-in-depth measure. If you ever add direct
// client access, open the rules narrowly per collection — do not widen
// the default.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
